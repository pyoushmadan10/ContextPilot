#!/usr/bin/env bash
# ContextPilot launcher for Claude Code
# Usage: cpx [project_path] [initial_prompt]
#
# - Kills any stale ctxpilot server for this project
# - Starts the MCP server in background
# - Tails server log for cost lines (prints to terminal)
# - Registers with Claude Code
# - Prints dashboard URL
# - Launches claude (with optional initial prompt)
# - On exit: cleans up server + tail processes

set -euo pipefail

PROJECT_PATH="${1:-}"
INITIAL_PROMPT="${2:-}"

# Default to current directory if no argument given
if [ -z "$PROJECT_PATH" ]; then
    PROJECT_PATH="$(pwd)"
fi

# Validate directory exists before resolving
if [ ! -d "$PROJECT_PATH" ]; then
    echo "ERROR: Directory '$PROJECT_PATH' does not exist."
    exit 1
fi

# Resolve absolute path (realpath preferred, cd+pwd fallback)
if command -v realpath > /dev/null 2>&1; then
    PROJECT_PATH="$(realpath "$PROJECT_PATH")"
else
    PROJECT_PATH="$(cd "$PROJECT_PATH" && pwd)"
fi
CTXPILOT_DIR="$PROJECT_PATH/.ctxpilot"
PID_FILE="$CTXPILOT_DIR/server.pid"
PORT_FILE="$CTXPILOT_DIR/server.port"
LOG_FILE="$CTXPILOT_DIR/server.log"

echo "╔══════════════════════════════════════════╗"
echo "║         ContextPilot — Claude Code       ║"
echo "╚══════════════════════════════════════════╝"
echo ""
echo "  Project: $PROJECT_PATH"

# Kill stale server if running
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        echo "  Stopping stale server (PID $OLD_PID)..."
        kill "$OLD_PID" 2>/dev/null || true
        sleep 1
    fi
    rm -f "$PID_FILE" "$PORT_FILE"
fi

# Ensure .ctxpilot dir exists
mkdir -p "$CTXPILOT_DIR"

# Ensure log file exists for tail
touch "$LOG_FILE"

# Start server in background completely detached
echo "  Starting ContextPilot..."
nohup uv run python -m contextpilot.server "$PROJECT_PATH" \
  >> "$LOG_FILE" 2>&1 &

SERVER_PID=$!
echo $SERVER_PID > "$CTXPILOT_DIR/server.pid"
disown $SERVER_PID

# Wait for HTTP server to be reachable (not for scan to complete)
MAX_WAIT=30
WAITED=0

while [ $WAITED -lt $MAX_WAIT ]; do
  # First check if port file exists so we know what port to curl
  if [ -f "$PORT_FILE" ]; then
    PORT=$(cat "$PORT_FILE")
    if curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; then
      HEALTH_JSON=$(curl -s "http://localhost:$PORT/health")
      echo "  ContextPilot server is up (indexing may continue in background)"
      echo "  Dashboard: http://localhost:$PORT/dashboard"
      break
    fi
  fi
  if [ $WAITED -eq 5 ]; then
    echo "  Waiting for server to start..."
  fi
  sleep 1
  WAITED=$((WAITED + 1))
done

if [ $WAITED -eq $MAX_WAIT ]; then
  echo "  ContextPilot server failed to start. Check .ctxpilot/server.log for details."
  exit 1
fi

PORT=$(cat "$PORT_FILE")
MCP_URL="http://localhost:${PORT}/mcp"
DASHBOARD_URL="http://localhost:${PORT}/dashboard"

echo ""

# Register MCP server with Claude Code
echo "  Registering MCP server with Claude Code..."
if claude mcp add --transport http contextpilot "$MCP_URL" 2>/dev/null; then
    echo "  MCP server registered successfully."
else
    echo ""
    echo "  ⚠  Could not auto-register MCP server with 'claude' CLI."
    echo "  Run this command manually to register:"
    echo ""
    echo "    claude mcp add --transport http contextpilot $MCP_URL"
    echo ""
fi

# Start tail -f for cost lines in terminal
TAIL_PID=""
HAS_COLOR=0
if command -v tput >/dev/null 2>&1; then
    COLORS=$(tput colors 2>/dev/null || echo 0)
    if [ "$COLORS" -ge 8 ] 2>/dev/null; then
        HAS_COLOR=1
    fi
fi

if [ "$HAS_COLOR" -eq 1 ]; then
    # Green for savings, reset after
    GREEN=$(tput setaf 2)
    RESET=$(tput sgr0)
    tail -f "$LOG_FILE" 2>/dev/null | \
        grep --line-buffered '\[ContextPilot\]' | \
        sed -u "s/saved \([0-9,]* tok (\$[0-9.]*)\)/${GREEN}saved \1${RESET}/g" &
    TAIL_PID=$!
else
    tail -f "$LOG_FILE" 2>/dev/null | \
        grep --line-buffered '\[ContextPilot\]' &
    TAIL_PID=$!
fi

# Cleanup function
cleanup() {
    echo ""
    echo "  Stopping ContextPilot server..."
    if kill -0 "$SERVER_PID" 2>/dev/null; then
        kill "$SERVER_PID" 2>/dev/null || true
    fi
    if [ -n "$TAIL_PID" ] && kill -0 "$TAIL_PID" 2>/dev/null; then
        kill "$TAIL_PID" 2>/dev/null || true
    fi
    rm -f "$PID_FILE" "$PORT_FILE"
    echo "  Done."
}
trap cleanup EXIT INT TERM

# Launch Claude Code
echo ""
echo "  Launching Claude Code..."
echo "  ────────────────────────"
echo ""

cd "$PROJECT_PATH"

if [ -n "$INITIAL_PROMPT" ]; then
    claude "$INITIAL_PROMPT"
else
    claude
fi
