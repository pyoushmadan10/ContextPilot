#!/usr/bin/env bash
# ContextPilot launcher for Codex CLI
# Usage: cpx-codex [project_path] [initial_prompt]
#
# Same as cpx but launches codex instead of claude.

set -euo pipefail

PROJECT_PATH="${1:-}"
INITIAL_PROMPT="${2:-}"

# Default to current directory if no argument given
if [ -z "$PROJECT_PATH" ]; then
    PROJECT_PATH="$(pwd)"
fi

# Validate directory exists before resolving
if [ ! -d "$PROJECT_PATH" ]; then
    echo "ERROR: Directory '$PROJECT_PATH' does not exist."
    exit 1
fi

# Resolve absolute path (realpath preferred, cd+pwd fallback)
if command -v realpath > /dev/null 2>&1; then
    PROJECT_PATH="$(realpath "$PROJECT_PATH")"
else
    PROJECT_PATH="$(cd "$PROJECT_PATH" && pwd)"
fi
CTXPILOT_DIR="$PROJECT_PATH/.ctxpilot"
PID_FILE="$CTXPILOT_DIR/server.pid"
PORT_FILE="$CTXPILOT_DIR/server.port"
LOG_FILE="$CTXPILOT_DIR/server.log"

echo "╔══════════════════════════════════════════╗"
echo "║         ContextPilot — Codex CLI         ║"
echo "╚══════════════════════════════════════════╝"
echo ""
echo "  Project: $PROJECT_PATH"

# Kill stale server if running
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        echo "  Stopping stale server (PID $OLD_PID)..."
        kill "$OLD_PID" 2>/dev/null || true
        sleep 1
    fi
    rm -f "$PID_FILE" "$PORT_FILE"
fi

mkdir -p "$CTXPILOT_DIR"

# Ensure log file exists for tail
touch "$LOG_FILE"

# Start server in background completely detached
echo "  Starting ContextPilot server..."
nohup uv run python -m contextpilot.server "$PROJECT_PATH" \
  >> "$LOG_FILE" 2>&1 &

SERVER_PID=$!
echo $SERVER_PID > "$CTXPILOT_DIR/server.pid"
disown $SERVER_PID

# Wait for HTTP server to be reachable
MAX_WAIT=90
WAITED=0

while [ $WAITED -lt $MAX_WAIT ]; do
  if [ -f "$PORT_FILE" ]; then
    PORT=$(cat "$PORT_FILE")
    if curl -s "http://localhost:$PORT/health" > /dev/null 2>&1; then
      if [ $WAITED -ge 5 ]; then
        echo ""
      fi
      echo "  ContextPilot server is up (indexing may continue in background)"
      echo "  Dashboard: http://localhost:$PORT/dashboard"
      break
    fi
  fi
  if [ $WAITED -eq 5 ]; then
    printf "  Waiting for server (setting up dependencies may take a moment)"
  fi
  if [ $WAITED -gt 5 ]; then
    printf "."
  fi
  sleep 1
  WAITED=$((WAITED + 1))
done

if [ $WAITED -eq $MAX_WAIT ]; then
  echo ""
  echo "  ContextPilot server failed to start. Check .ctxpilot/server.log for details."
  exit 1
fi

PORT=$(cat "$PORT_FILE")
MCP_URL="http://localhost:${PORT}/mcp"
DASHBOARD_URL="http://localhost:${PORT}/dashboard"

echo ""

echo "  Registering MCP server with Codex CLI..."
if codex mcp add contextpilot --url "$MCP_URL" 2>/dev/null; then
    echo "  MCP server registered successfully."
else
    echo ""
    echo "  ⚠  Could not auto-register MCP server with 'codex' CLI."
    echo "  Run this command manually to register:"
    echo ""
    echo "    codex mcp add contextpilot --url $MCP_URL"
    echo ""
fi

# Start tail -f for cost lines in terminal
TAIL_PID=""
HAS_COLOR=0
if command -v tput >/dev/null 2>&1; then
    COLORS=$(tput colors 2>/dev/null || echo 0)
    if [ "$COLORS" -ge 8 ] 2>/dev/null; then
        HAS_COLOR=1
    fi
fi

if [ "$HAS_COLOR" -eq 1 ]; then
    GREEN=$(tput setaf 2)
    RESET=$(tput sgr0)
    tail -f "$LOG_FILE" 2>/dev/null | \
        grep --line-buffered '\[ContextPilot\]' | \
        sed -u "s/saved \([0-9,]* tok (\$[0-9.]*)\)/${GREEN}saved \1${RESET}/g" &
    TAIL_PID=$!
else
    tail -f "$LOG_FILE" 2>/dev/null | \
        grep --line-buffered '\[ContextPilot\]' &
    TAIL_PID=$!
fi

cleanup() {
    echo ""
    echo "  Stopping ContextPilot server..."
    if kill -0 "$SERVER_PID" 2>/dev/null; then
        kill "$SERVER_PID" 2>/dev/null || true
    fi
    if [ -n "$TAIL_PID" ] && kill -0 "$TAIL_PID" 2>/dev/null; then
        kill "$TAIL_PID" 2>/dev/null || true
    fi
    rm -f "$PID_FILE" "$PORT_FILE"
    echo "  Done."
}
trap cleanup EXIT INT TERM

echo ""
echo "  Launching Codex CLI..."
echo "  ────────────────────────"
echo ""

cd "$PROJECT_PATH"

if [ -n "$INITIAL_PROMPT" ]; then
    codex "$INITIAL_PROMPT"
else
    codex
fi
